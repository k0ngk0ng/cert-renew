# ===== ACME / DNS =====
# Let's Encrypt account email
ACME_ACCOUNT_EMAIL=admin@example.com

# Aliyun DNS API credentials
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# ACME CA: letsencrypt | zerossl
ACME_CA=letsencrypt

# ===== Certificate definitions =====
# Nginx cert domains, comma separated
NGINX_CERT_NAME=nginx-yunhongfu
NGINX_DOMAINS=api.yunhongfu.com,erp.yunhongfu.com,status.yunhongfu.com

# CDN cert
CDN_CERT_NAME=cdn-yunhongfu
CDN_DOMAIN=cdn.yunhongfu.com

# WeChat cert
WECHAT_CERT_NAME=wxapp-yunhongfu
WECHAT_DOMAIN=wxapp.yunhongfu.com

# ===== Install paths =====
ACME_HOME=/opt/acme.sh
CERT_HOME=/opt/cert-manager/certs
STATE_DIR=/opt/cert-manager/state
WORK_DIR=/opt/cert-manager/work
NGINX_SSL_DIR=/etc/nginx/ssl

# ===== Nginx deployment =====
NGINX_SERVICE_NAME=nginx
NGINX_RELOAD_CMD="nginx -t && systemctl reload nginx"

# ===== SMTP =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=sender@example.com
SMTP_TO=ops1@example.com,ops2@example.com
SMTP_USE_SSL=true
SMTP_SUBJECT_PREFIX=[yunhongfu-cert]

# ===== ZIP password =====
ZIP_PASSWORD=change_this_password

# ===== Mail behavior =====
# Comma separated names from: cdn,wechat
MAIL_CERT_TARGETS=cdn,wechat

# ===== Optional =====
# For Let's Encrypt test environment: 1=true, 0=false
ACME_STAGING=0
